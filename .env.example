# -----------------------------------------------------------------------------
# Core runtime
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/tilo
REDIS_URL=redis://redis:6379/0
JWT_SECRET=change-me
PUBLIC_APP_URL=http://localhost:4001

# -----------------------------------------------------------------------------
# LLM runtime
#
# Default is deterministic demo mode so the project works after clone without
# any model provider key.
#
# Recommended setup for built-in providers:
#   LLM_ENABLED=true
#   LLM_PROVIDER=deepseek
#   DEEPSEEK_API_KEY=...
#   DEFAULT_MODEL=deepseek-chat
#
# Tencent Cloud DeepSeek setup:
#   LLM_ENABLED=true
#   LLM_PROVIDER=tencent
#   TENCENT_API_KEY=...
#   DEFAULT_MODEL=deepseek-v4-pro
#
# Recommended setup for custom OpenAI-compatible gateways:
#   LLM_ENABLED=true
#   LLM_PROVIDER=custom
#   LLM_API_KEY=...
#   LLM_BASE_URL=https://your-gateway.example.com/v1
#   DEFAULT_MODEL=your-model-name
#
# Supported LLM_PROVIDER values:
#   openai, anthropic, deepseek, google, gemini, xai, mistral, groq,
#   openrouter, together, qwen, dashscope, tencent, tencent_deepseek,
#   moonshot, kimi, zhipu, glm, azure_openai, openai_compatible, custom
# -----------------------------------------------------------------------------
LLM_ENABLED=false
LLM_PROVIDER=openai
DEFAULT_MODEL=gpt-4.1-mini
LLM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=2

# Disable extended thinking on reasoning models (Kimi K2.6, Qwen3-Thinking,
# etc.). Tilo's spec generator is a structured-output task — chain-of-thought
# adds 60-180s of latency without quality gain. Set to true only if you
# specifically want to expose `reasoning_content` to users.
LLM_THINKING_ENABLED=false

# Use these for custom gateways or if you prefer one generic key variable.
LLM_API_KEY=
LLM_BASE_URL=

# Provider-specific keys. Only set the one matching LLM_PROVIDER.
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
TOGETHER_API_KEY=
QWEN_API_KEY=
TENCENT_API_KEY=
MOONSHOT_API_KEY=
ZHIPU_API_KEY=

# Legacy OpenAI-compatible settings. Kept for compatibility with older config.
# Prefer LLM_PROVIDER / LLM_API_KEY / LLM_BASE_URL for new setups.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Reserved for future embedding memory/pgvector work. Not required today.
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small

# -----------------------------------------------------------------------------
# Telegram channel adapter
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
